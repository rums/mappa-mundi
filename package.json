{
  "name": "mappa-mundi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite",
    "build": "tsc && vite build",
    "start:api": "tsx src/api/main.ts",
    "dev:api": "tsx watch src/api/main.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:api\""
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "d3": "^7.9.0",
    "fastify": "^5.8.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@swc/core": "^1.4.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/d3": "^7.4.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "vitest": "^1.3.0"
  }
}
